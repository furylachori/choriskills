set -euo pipefail

if [ $# -ne 1 ]; then
    echo "Usage: $0 <STEPFUN_API_KEY>"
    exit 1
fi

API_KEY="$1"
REPO_URL="https://github.com/furylachori/choriskills.git"
CLONE_DIR="/tmp/choriskills"
SKILLS=("stepfun-image" "stepfun-tts" "stepfun-asr")

echo "==> Cloning/updating repo..."
if [ -d "$CLONE_DIR" ]; then
    git -C "$CLONE_DIR" pull --ff-only
else
    git clone --depth 1 "$REPO_URL" "$CLONE_DIR"
fi

for skill in "${SKILLS[@]}"; do
    echo "==> Installing $skill..."
    zeroclaw skills install "$CLONE_DIR/$skill"

    SKILL_DIR="$HOME/.zeroclaw/workspace/skills/$skill"
    if [ -d "$SKILL_DIR" ]; then
        echo "STEPFUN_API_KEY=$API_KEY" > "$SKILL_DIR/.env"
        echo "    .env written to $SKILL_DIR/.env"
    else
        echo "    WARNING: $SKILL_DIR not found, skill may have failed to install"
    fi
done

echo "==> Done. Installed skills:"
zeroclaw skills list
